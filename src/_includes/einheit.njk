---
layout: base.njk
---
<section class="section section-detail">
  <div class="container">
    <nav class="breadcrumb-back" aria-label="Breadcrumb">
      <a href="/einheiten/"><svg class="icon" style="transform:rotate(180deg)" aria-hidden="true"><use href="#icon-chevron"></use></svg> Einheiten</a>
    </nav>

    {% set gesamtdauer = 0 %}
    {% for phase in phasen %}{% set gesamtdauer = gesamtdauer + (phase.minuten | int(0)) %}{% endfor %}

    <div class="detail-header">
      <span class="tag tag--category">🗂️ Trainingseinheit</span>
      <h1>{{ title }}</h1>
      <div class="detail-stats">
        <div class="detail-stat">
          <span class="detail-stat-label">Schwerpunkt</span>
          <span class="detail-stat-value">{{ schwerpunkt }}</span>
        </div>
        <div class="detail-stat">
          <span class="detail-stat-label">Altersgruppen</span>
          <span class="detail-stat-value">{% for a in altersgruppen %}{{ site.altersgruppen[a] }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
        </div>
        <div class="detail-stat detail-stat--accent">
          <span class="detail-stat-label">Gesamtdauer</span>
          <span class="detail-stat-value">{{ gesamtdauer }} Min</span>
        </div>
      </div>
    </div>

    {% if content %}<div class="detail-main">{{ content | safe }}</div>{% endif %}

    <ol class="timeline">
      {% for phase in phasen %}
      <li class="timeline-item">
        <div class="timeline-marker"><span class="timeline-num">{{ loop.index }}</span></div>
        <div class="timeline-content">
          <div class="timeline-item-head">
            <h2>{{ phase.name }}</h2>
            <span class="tag tag--minutes">{{ phase.minuten | int(0) }} Min</span>
          </div>
          <div class="timeline-exercises">
            {% for slug in phase.uebungen %}
              {% set ex = collections.uebungen | bySlug(slug) %}
              {% if ex %}
              <a class="timeline-exercise" href="{{ ex.url }}">
                <span class="card-icon-badge">{{ site.kategorien[ex.data.kategorie].icon }}</span>
                <span class="timeline-exercise-body">
                  <span class="timeline-exercise-title">{{ ex.data.title }}</span>
                  <span class="timeline-exercise-meta">{{ site.kategorien[ex.data.kategorie].label }} · {{ ex.data.ziel }}</span>
                </span>
                <span class="card-cta">Details <svg class="icon" aria-hidden="true"><use href="#icon-chevron"></use></svg></span>
              </a>
              {% else %}
              <p class="card-source">⚠️ Übung nicht gefunden: <code>{{ slug }}</code></p>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </li>
      {% endfor %}
    </ol>
  </div>
</section>
